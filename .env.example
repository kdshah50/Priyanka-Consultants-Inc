# =============================================================================
# Stripe — take payment on the web (hosted checkout)
# =============================================================================
#
# This site uses Stripe Payment Links (no backend required). Each link opens
# Stripe’s secure page where customers pay by card, Apple Pay, Google Pay, etc.
#
# SETUP (do this in dashboard.stripe.com)
#
# 1) Complete Stripe account activation (business details, bank for payouts).
#
# 2) For EACH course price, create a Product + Price (or reuse one Price):
#    Products → Add product → set price (one-time) → Save.
#
# 3) Create a Payment Link for that price:
#    Payment Links → New → choose the product/price → copy the full URL.
#    It looks like: https://buy.stripe.com/... or https://buy.stripe.com/test/... (test mode)
#
# 4) Paste that URL into the matching variable below. Use Test mode links while
#    developing; switch to Live mode links for production.
#
# 5) Deploy env vars to Vercel:
#    Project → Settings → Environment Variables → add each VITE_* variable
#    for Production (and Preview if you want). Redeploy the site.
#
# 6) Optional: In the Payment Link settings, enable “Allow promotion codes”,
#    collect phone/billing if you need them, and set a confirmation page URL.
#
# FALLBACK: If a course-specific variable is empty, VITE_STRIPE_PAYMENT_LINK is
# used (same price for every course). If all are empty, the site falls back to
# phone / email enrollment.
#
# Docs: https://stripe.com/docs/payment-links

# Optional: single Payment Link used for any course that has no per-course URL
VITE_STRIPE_PAYMENT_LINK=

# Per course — URLs must match the listed price for that course in src/App.jsx
VITE_STRIPE_LINK_LEADING_SAFE=
VITE_STRIPE_LINK_SAFE_PO_PM=
VITE_STRIPE_LINK_SAFE_RTE=
VITE_STRIPE_LINK_SAFE_LPM=
VITE_STRIPE_LINK_SAFE_SM=
VITE_STRIPE_LINK_SAFE_DEVOPS=

VITE_STRIPE_LINK_GEN_AI_RAG=
VITE_STRIPE_LINK_PROMPT_ENG=
VITE_STRIPE_LINK_AI_AGENTS=
VITE_STRIPE_LINK_MODERN_ENG=

VITE_STRIPE_LINK_CLOUD_MIGRATION=
VITE_STRIPE_LINK_FINOPS=
VITE_STRIPE_LINK_AZURE_DEVOPS=

VITE_STRIPE_LINK_AGILE_SCRUM=
VITE_STRIPE_LINK_JIRA_ALIGN=

# Site URL for JSON-LD / canonical context (no trailing slash). Production example: https://www.yourdomain.com
VITE_SITE_URL=

# Shown in mailto links for fit call & corporate training (hero + corporate section)
VITE_CONTACT_EMAIL=
